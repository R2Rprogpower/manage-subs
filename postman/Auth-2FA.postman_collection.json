  "item": [
    {
      "name": "Signup",
      "item": [
        {
          "name": "Sign Up",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json?.data?.user?.id) {",
                  "    pm.collectionVariables.set('userId', String(json.data.user.id));",
                  "}",
                  "pm.test('User created', function () {",
                  "    pm.expect(json?.data?.user?.email).to.eql(pm.collectionVariables.get('email'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"password_confirmation\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/signup",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "signup"
              ]
            },
            "description": "Creates a new user account. Run this first before MFA setup if the user does not exist yet."
          },
          "response": []
        }
      ]
    },
    {
      "name": "MFA",
      "item": [
        {
          "name": "Setup MFA",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json?.data?.otpauth_url) {",
                  "    pm.collectionVariables.set('otpauthUrl', json.data.otpauth_url);",
                  "}",
                  "if (Array.isArray(json?.data?.recovery_codes) && json.data.recovery_codes.length > 0) {",
                  "    pm.collectionVariables.set('recoveryCode', json.data.recovery_codes[0]);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/mfa/setup",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "mfa",
                "setup"
              ]
            },
            "description": "Initializes MFA and returns `secret`, `otpauth_url`, and `recovery_codes`. Scan the returned `otpauth_url` in Google Authenticator or use one recovery code later if needed."
          },
          "response": []
        },
        {
          "name": "Verify MFA",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('MFA verified', function () {",
                  "    pm.expect(json?.data?.verified).to.eql(true);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"mfa_token\": \"{{mfaToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/mfa/verify",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "mfa",
                "verify"
              ]
            },
            "description": "Verifies the current 6-digit TOTP from Google Authenticator. Set `mfaToken` before sending."
          },
          "response": []
        }
      ]
    },
